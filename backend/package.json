  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.0.0",
    "typescript": "~5.9.3",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0"
  }
}
