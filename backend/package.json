  "description": "AgentMonitor Backend - AI Agent 质量监控与调试平台",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:simple": "tsx watch src/simple-server.ts",
    "dev:mvp": "tsx watch src/mvp-server.ts",
    "dev:mvp:js": "node --watch mvp-server.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:simple": "tsx src/simple-server.ts",
    "start:mvp": "tsx src/mvp-server.ts",
    "start:mvp:js": "node mvp-server.js",
    "test": "vitest",
    "lint": "eslint ."
  },
  "author": "AgentMonitor Team",
